{
  "name": "Run WebAPI",
  "type": "coreclr",
  "request": "launch",
  "preLaunchTask": "build",
  "program": "${workspaceFolder}/WebApi/bin/Debug/net8.0/WebApi",
  "args": [],
  "cwd": "${workspaceFolder}/WebApi",
  "stopAtEntry": false,
  "serverReadyAction": {
    "action": "openExternally",
    "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
  },
  "hotReloadEnabled": true // Add this line
}
